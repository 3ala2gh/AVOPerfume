enum Gender {
  MALE
  FEMALE
  UNISEX
}

model Perfume {
  id          Int      @id @default(autoincrement())
  name        String
  gender      Gender   @default(UNISEX)
  price       Decimal
  description String?
  imageUrl    String?
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
}
